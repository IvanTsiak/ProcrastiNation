                                </svg>
                                Головна
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Global" asp-action="Index" class="nav-link">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M12 0C9.62662 0 7.30655 0.703788 5.33316 2.02236C3.35977 3.34094 1.8217 5.21509 0.913445 7.4078C0.00519371 9.60051 -0.232446 12.0133 0.230576 14.3411C0.693599 16.6689 1.83649 18.8071 3.51472 20.4853C5.19295 22.1635 7.33114 23.3064 9.65892 23.7694C11.9867 24.2324 14.3995 23.9948 16.5922 23.0866C18.7849 22.1783 20.6591 20.6402 21.9776 18.6668C23.2962 16.6935 24 14.3734 24 12C23.9966 8.81846 22.7312 5.76821 20.4815 3.51852C18.2318 1.26883 15.1815 0.00344108 12 0V0ZM20.647 7H17.426C16.705 5.32899 15.7556 3.76609 14.605 2.356C17.1515 3.04893 19.3223 4.71747 20.647 7ZM16.5 12C16.4918 13.0181 16.3313 14.0293 16.024 15H7.976C7.66865 14.0293 7.50821 13.0181 7.5 12C7.50821 10.9819 7.66865 9.97068 7.976 9H16.024C16.3313 9.97068 16.4918 10.9819 16.5 12ZM8.778 17H15.222C14.3732 18.6757 13.2882 20.2208 12 21.588C10.7114 20.2212 9.62624 18.676 8.778 17ZM8.778 7C9.62676 5.32427 10.7118 3.77916 12 2.412C13.2886 3.77877 14.3738 5.32396 15.222 7H8.778ZM9.4 2.356C8.24766 3.76578 7.29658 5.3287 6.574 7H3.353C4.67885 4.71643 6.85166 3.04775 9.4 2.356ZM2.461 9H5.9C5.64076 9.97915 5.50636 10.9871 5.5 12C5.50636 13.0129 5.64076 14.0209 5.9 15H2.461C1.84634 13.0472 1.84634 10.9528 2.461 9ZM3.353 17H6.574C7.29658 18.6713 8.24766 20.2342 9.4 21.644C6.85166 20.9522 4.67885 19.2836 3.353 17ZM14.605 21.644C15.7556 20.2339 16.705 18.671 17.426 17H20.647C19.3223 19.2825 17.1515 20.9511 14.605 21.644ZM21.539 15H18.1C18.3592 14.0209 18.4936 13.0129 18.5 12C18.4936 10.9871 18.3592 9.97915 18.1 9H21.537C22.1517 10.9528 22.1517 13.0472 21.537 15H21.539Z" fill="black" />
                                </svg>
                                Зал слави
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Logs" asp-action="Create" class="nav-link">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M12 0C9.62662 0 7.30655 0.703788 5.33316 2.02236C3.35977 3.34094 1.8217 5.21509 0.913445 7.4078C0.00519371 9.60051 -0.232446 12.0133 0.230576 14.3411C0.693599 16.6689 1.83649 18.8071 3.51472 20.4853C5.19295 22.1635 7.33114 23.3064 9.65892 23.7694C11.9867 24.2324 14.3995 23.9948 16.5922 23.0866C18.7849 22.1783 20.6591 20.6402 21.9776 18.6668C23.2962 16.6935 24 14.3734 24 12C23.9966 8.81846 22.7312 5.76821 20.4815 3.51852C18.2318 1.26883 15.1815 0.00344108 12 0V0ZM12 22C10.0222 22 8.08879 21.4135 6.4443 20.3147C4.79981 19.2159 3.51808 17.6541 2.7612 15.8268C2.00433 13.9996 1.80629 11.9889 2.19215 10.0491C2.578 8.10929 3.53041 6.32746 4.92893 4.92893C6.32746 3.53041 8.10929 2.578 10.0491 2.19215C11.9889 1.8063 13.9996 2.00433 15.8268 2.7612C17.6541 3.51808 19.2159 4.79981 20.3147 6.4443C21.4135 8.08879 22 10.0222 22 12C21.9971 14.6513 20.9426 17.1931 19.0679 19.0679C17.1931 20.9426 14.6513 21.9971 12 22ZM13 11H17V13H13V17H11V13H7V11H11V7H13V11Z" fill="black" />
                                </svg>
                                Створити запис
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Achievements" asp-action="Index" class="nav-link">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M15.067 16C21.656 15.973 24 12.488 24 9.5C23.9993 8.70078 23.7252 7.92585 23.2231 7.30404C22.721 6.68222 22.0212 6.25098 21.24 6.08201C21.5289 5.26899 21.7628 4.43744 21.94 3.593C22.0288 3.1607 22.0198 2.71401 21.9138 2.28561C21.8077 1.85721 21.6072 1.45794 21.327 1.117C21.0432 0.76754 20.685 0.48589 20.2784 0.292635C19.8718 0.0993791 19.4272 -0.000599469 18.977 4.22236e-06H5.023C4.57266 -0.000748534 4.12784 0.0991583 3.72108 0.292419C3.31431 0.48568 2.95588 0.767409 2.672 1.117C2.39176 1.45794 2.19128 1.85721 2.08521 2.28561C1.97915 2.71401 1.9702 3.1607 2.059 3.593C2.23573 4.43756 2.4696 5.26914 2.759 6.08201C1.97803 6.25118 1.27846 6.68251 0.776546 7.3043C0.274635 7.9261 0.000607496 8.70092 0 9.5C0 12.488 2.344 15.973 8.933 16C8.97041 16.2105 8.9928 16.4234 9 16.637V20C9.01718 20.2671 8.97723 20.5348 8.88279 20.7852C8.78836 21.0357 8.64162 21.2631 8.45237 21.4524C8.26311 21.6416 8.03568 21.7884 7.78524 21.8828C7.53479 21.9772 7.2671 22.0172 7 22H5V24H19V22H17.008C16.7403 22.018 16.4719 21.9788 16.2206 21.8847C15.9694 21.7907 15.7411 21.6441 15.551 21.4548C15.3609 21.2655 15.2134 21.0378 15.1184 20.7869C15.0234 20.536 14.983 20.2677 15 20V16.637C15.0072 16.4234 15.0296 16.2105 15.067 16ZM20.5 8C20.8978 8 21.2794 8.15804 21.5607 8.43934C21.842 8.72065 22 9.10218 22 9.5C22 11.548 20.369 13.725 15.876 13.975C16.0528 13.7427 16.257 13.5325 16.484 13.349C18.1888 11.8861 19.542 10.0578 20.443 8H20.5ZM2 9.5C2 9.10218 2.15804 8.72065 2.43934 8.43934C2.72064 8.15804 3.10218 8 3.5 8H3.557C4.45729 10.058 5.8102 11.8863 7.515 13.349C7.74234 13.5325 7.9468 13.7427 8.124 13.975C3.631 13.725 2 11.548 2 9.5ZM13 16.637V20C12.9887 20.6973 13.1564 21.3859 13.487 22H10.513C10.8436 21.3859 11.0113 20.6973 11 20V16.637C11.017 15.7122 10.8247 14.7955 10.4375 13.9555C10.0503 13.1154 9.47818 12.3738 8.764 11.786C6.3 9.816 4.6 6.05 4.018 3.19C3.98811 3.04881 3.99057 2.90267 4.02521 2.76256C4.05985 2.62246 4.12576 2.49201 4.218 2.381C4.31507 2.26126 4.43781 2.16485 4.57715 2.0989C4.71648 2.03296 4.86885 1.99916 5.023 2H18.977C19.1303 1.99991 19.2817 2.03406 19.4201 2.09998C19.5585 2.1659 19.6805 2.26191 19.777 2.381C19.869 2.49216 19.9347 2.62261 19.9694 2.76267C20.004 2.90273 20.0066 3.0488 19.977 3.19C19.391 6.05 17.695 9.816 15.23 11.79C14.5176 12.3781 13.947 13.1193 13.5609 13.9586C13.1748 14.7978 12.9831 15.7134 13 16.637Z" fill="black" />
                                </svg>
                                Досягнення
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="px-4 pb-4">
                    <div class="border-t border-text/40 pt-4">
                        <a asp-controller="Profile" asp-action="Index" class="nav-link">
                            <svg class="w-5 h-5 text-black" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                            Профіль
                        </a>
                    </div>
                </div>

            </div>

        }
        <main class="flex-1 p-8">
            @RenderBody()
        </main>

    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (TempData["PendingAchievement"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                if (typeof tryUnlockAchievement === 'function') {
                    tryUnlockAchievement('@TempData["PendingAchievement"]');
                }
            });
        </script>
    }

    @if (TempData["PendingTitle"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                if (typeof tryUnlockTitle === 'function') {
                    tryUnlockTitle('@TempData["PendingTitle"]');
                }
            });
        </script>
    }

    @if (User.IsInRole("Admin"))
    {
        <div id="adminFab" class="fab hidden fixed bottom-6 right-6 z-50" style="position: fixed;">

            <div tabindex="0" role="button" class="btn btn-lg btn-circle bg-amber-500 text-white border-none shadow-xl hover:bg-amber-600">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75" /></svg>
            </div>

            <div class="fab-close">
                <span class="btn btn-circle btn-lg btn-error shadow-lg text-white font-black">✕</span>
            </div>

            <div>
                <span class="mr-2 text-text font-bold text-sm bg-surface/90 px-2 py-1 rounded-lg shadow-sm">Користувачі</span>
                <a asp-controller="Admin" asp-action="Users" class="btn btn-lg btn-circle bg-surface border-secondary/50 text-xl hover:bg-secondary/20 shadow-lg">👥</a>
            </div>
            <div>
                <span class="mr-2 text-text font-bold text-sm bg-surface/90 px-2 py-1 rounded-lg shadow-sm">Активності</span>
                <a asp-controller="Activities" asp-action="Index" class="btn btn-lg btn-circle bg-surface border-secondary/50 text-xl hover:bg-secondary/20 shadow-lg">📋</a>
            </div>
            <div>
                <span class="mr-2 text-text font-bold text-sm bg-surface/90 px-2 py-1 rounded-lg shadow-sm">Титули</span>
                <a asp-controller="Titles" asp-action="Manage" class="btn btn-lg btn-circle bg-surface border-secondary/50 text-xl hover:bg-secondary/20 shadow-lg">✨</a>
            </div>
            <div>
                <span class="mr-2 text-text font-bold text-sm bg-surface/90 px-2 py-1 rounded-lg shadow-sm">Аналітика</span>
                <a asp-controller="Admin" asp-action="Analytics" class="btn btn-lg btn-circle bg-surface border-secondary/50 text-xl hover:bg-secondary/20 shadow-lg">📈</a>
            </div>
        </div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
                if (localStorage.getItem('showAdminFab') === 'true') {
                    document.getElementById('adminFab').classList.remove('hidden');
                }
            });
        </script>
    }

</body>
</html>
