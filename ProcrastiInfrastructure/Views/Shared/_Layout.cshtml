<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProcrastiNation</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/app.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProcrastiInfrastructure.styles.css" asp-append-version="true" />
</head>
<body class="font-sans bg-background text-text">

    <div class="flex min-h-screen">

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <div class="w-64 h-screen bg-background flex flex-col sticky top-0 border-r border-text/40 shrink-0">

                <div class="px-6 py-6 border-b border-text/40">
                    <h1 class="text-2xl font-black tracking-tight text-text">ProcrastiNation</h1>
                </div>

                <div class="flex-1 px-4 py-2">
                    <h3 class="text-xs font-sin text-text/50 uppercase tracking-widest mb-2 px-2">
                        Навігація
                    </h3>

                    <ul class="space-y-1">
                        <li>
                            <a asp-controller="Home" asp-action="Index" class="nav-link">
