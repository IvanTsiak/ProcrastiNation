@using ProcrastiDomain.Model

@inject ProcrastiInfrastructure.Services.ICurrentUserService CurrentUserService
@model Log

@{
    bool isLoss = Model.Logtype == LogType.loss;
    string actionColorClass = isLoss ? "text-rose" : "text-emerald";
    string sign = isLoss ? "Програв" : "Насолоджувався";

    string likeBtnId = $"like-btn-{Model.Id}";
    string likeCountId = $"like-count-{Model.Id}";

    bool isAuthenticated = User.Identity?.IsAuthenticated == true;
    int currentUserId = isAuthenticated ? CurrentUserService.GetCurrentUserId() : 0;
    bool isLikedByCurrentUser = isAuthenticated && Model.Likes != null && Model.Likes.Any(l => l.Userid == currentUserId);

    string btnColorClass = isLikedByCurrentUser ? "text-rose" : "text-text";
    string heartFill = isLikedByCurrentUser ? "currentColor" : "none";
}

<div class="border-b border-secondary/40 p-5 mb-2">

    <div class="flex justify-between items-start">
        <div class="flex items-start gap-3">
            <img src="@(string.IsNullOrEmpty(Model.User?.Profilepicture) ? "/images/avatars/default-avatar.png" : Model.User.Profilepicture)"
                 alt="Avatar"
                 class="w-11 h-11 rounded-full shrink-0 object-cover border border-secondary/20" />

            <div class="flex flex-col">
                <div class="flex items-baseline gap-2">
                    <span class="font-extrabold text-text text-base">@(Model.User?.Username ?? "Анонім")</span>
                    <span class="text-primary text-sm">@(Model.Createdat?.ToString("dd.MM.yyyy") ?? "")</span>
                </div>

                @if (Model.User?.Title != null)
                {
                    <span class="text-accent font-bold text-sm">
                        @Model.User.Title.Name
                    </span>
                }
            </div>
        </div>

        <div class="flex items-center gap-0.5 mt-1">
            @for (int i = 1; i <= 5; i++)
            {
                if (i <= Model.Rating)
                {
                    <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                }
                else
                {
                    <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
                }
            }
        </div>
    </div>

    <div class="font-bold text-base mt-3 @actionColorClass">
        @sign @Model.Amount хв у "@(Model.Activity?.Name ?? "Не знати де")"
    </div>

    @if (!string.IsNullOrEmpty(Model.Comment))
    {
        <div class="mt-2 border-l-2 border-primary pl-3 py-1 text-text text-base whitespace-pre-line max-w-3xl">@Model.Comment</div>
    }

    <div class="mt-4 flex items-center gap-5 text-base font-bold text-text">
        @if (isAuthenticated)
        {
            <button id="@likeBtnId" onclick="likeLog(@Model.Id)" class="flex items-center gap-1.5 transition-colors cursor-pointer @btnColorClass hover:text-rose">
                <svg class="w-5 h-5" fill="@heartFill" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                <span id="@likeCountId">@(Model.Likescount ?? 0)</span>
            </button>

            <button onclick="toggleComment(@Model.Id)" class="flex items-center gap-1.5 transition-colors cursor-pointer hover:text-primary">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                <span id="comment-count-@Model.Id">@(Model.Comments?.Count ?? 0)</span>
            </button>
        }
        else
        {
            <a href="/Account/Login" class="flex items-center gap-1.5 transition-colors cursor-pointer text-text hover:text-rose">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                <span>@(Model.Likescount ?? 0)</span>
            </a>

            <button onclick="toggleComment(@Model.Id)" class="flex items-center gap-1.5 transition-colors cursor-pointer hover:text-primary">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                <span>@(Model.Comments?.Count ?? 0)</span>
            </button>
        }
    </div>

    <div id="comments-section-@Model.Id" style="display: none;" class="mt-4 pt-4 border-t border-secondary/40">
        <div id="comments-list-@Model.Id" style="max-height: 400px; overflow-y: auto; margin-bottom: 10px;" class="pr-2">

            @if (Model.Comments != null)
            {
                var rootComments = Model.Comments.Where(c => c.Parentcommentid == null).OrderBy(x => x.Createdat).ToList();

                foreach (var c in rootComments)
                {
                    <div class="border-b border-secondary/20 py-3 last:border-0" id="comment-container-@c.Id">

                        <div class="flex items-start gap-3">
                            <img src="@(string.IsNullOrEmpty(c.Author?.Profilepicture) ? "/images/avatars/default-avatar.png" : c.Author.Profilepicture)"
                                 alt="Avatar"
                                 class="w-8 h-8 rounded-full shrink-0 object-cover border border-secondary/20" />

                            <div class="flex flex-col flex-1">
                                <div class="flex items-baseline gap-2">
                                    <strong class="text-text text-sm">@(c.Author?.Username ?? "Анонім")</strong>
                                    <span class="text-primary text-xs">@(c.Createdat?.ToString("dd.MM.yyyy"))</span>
                                </div>

                                @if (c.Author?.Title != null)
                                {
                                    <span class="text-accent text-xs -mt-0.5 mb-1">
                                        @(c.Author.Title.Name)
                                    </span>
                                }

                                <div class="mt-0.5 text-text text-sm">@c.Content</div>

                                @if (isAuthenticated)
                                {
                                    <button onclick="setReplyContext(@Model.Id, @c.Id, '@(c.Author?.Username)')" class="text-xs text-primary/50 font-bold mt-1 text-left w-fit hover:text-accent transition-colors">Відповісти</button>
                                }
                            </div>
                        </div>

                        @{
                            var replies = Model.Comments.Where(x => x.Parentcommentid == c.Id).OrderBy(x => x.Createdat).ToList();
                        }

                        <div class="ml-11 mt-1">
                            @if (replies.Any())
                            {
                                <button onclick="toggleReplies(@c.Id)" id="reply-toggle-btn-@c.Id" class="text-xs text-text/50 font-bold flex items-center gap-2 hover:text-text transition-colors mt-2">
                                    <span id="reply-toggle-text-@c.Id">---Показати відповіді (@replies.Count)---</span>
                                </button>
                            }

                            <div id="replies-list-@c.Id" class="@(replies.Any() ? "hidden" : "") mt-3 space-y-3">
                                @foreach (var r in replies)
                                {
                                    <div class="flex items-start gap-2">
                                        <img src="@(string.IsNullOrEmpty(r.Author?.Profilepicture) ? "/images/avatars/default-avatar.png" : r.Author.Profilepicture)"
                                             alt="Avatar" class="w-6 h-6 rounded-full shrink-0 object-cover border border-secondary/20" />
                                        <div class="flex flex-col flex-1">
                                            <div class="flex items-baseline gap-2">
                                                <strong class="text-text text-xs">@(r.Author?.Username ?? "Анонім")</strong>
                                                <span class="text-primary text-[10px]">@(r.Createdat?.ToString("dd.MM.yyyy"))</span>
                                            </div>

                                            @if (r.Author?.Title != null)
                                            {
                                                <span class="text-accent font-bold text-[10px] -mt-0.5 mb-1">
                                                    @(r.Author.Title.Name)
                                                </span>
                                            }
                                            <div class="text-text text-sm">@r.Content</div>

                                            @if (isAuthenticated)
                                            {
                                                <button onclick="setReplyContext(@Model.Id, @c.Id, '@(r.Author?.Username)')" class="text-[10px] text-primary font-bold mt-0.5 text-left w-fit hover:text-accent transition-colors">Відповісти</button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                    </div>
                }
            }
        </div>

        @if (isAuthenticated)
        {
            <div class="mt-2">
                <div id="reply-badge-@Model.Id" class="hidden mb-2 text-xs font-bold text-accent flex items-center gap-2 bg-accent/10 w-fit px-2 py-1 rounded-lg">
                    <span>Відповідь для <span id="reply-to-name-@Model.Id"></span></span>
                    <button onclick="cancelReply(@Model.Id)" class="hover:text-rose cursor-pointer ml-1">✕</button>
                </div>

                <div class="flex items-center gap-3">
                    <input type="hidden" id="parent-comment-id-@Model.Id" value="" />
                    <input type="text" id="comment-input-@Model.Id" class="flex-1 bg-transparent border border-secondary p-2 rounded text-text text-sm focus:outline-none focus:border-accent" placeholder="Напишіть щось..." />
                    <button onclick="submitComment(@Model.Id)" class="bg-primary text-background px-4 py-2 rounded text-sm font-bold hover:bg-text transition-colors">Send</button>
                </div>
            </div>
        }
        else
        {
            <div class="mt-4 text-center text-sm font-bold text-primary">
                <a href="/Account/Login" class="text-accent hover:underline">Увійдіть</a>, щоб залишити коментар
            </div>
        }
    </div>
</div>
<script>
    if (typeof likeLog !== 'function') {
        window.likeLog = async function(logId) {
            try {
                const response = await fetch(`/Logs/ToggleLike/${logId}`, {
                    method: 'POST'
                });

                if (response.ok) {
                    const data = await response.json();

                    document.getElementById(`like-count-${logId}`).innerText = data.newLikesCount;

                    const btn = document.getElementById(`like-btn-${logId}`);
                    const svg = btn.querySelector('svg');
                    if (data.isLiked) {
                        svg.setAttribute('fill', 'currentColor');
                        btn.classList.add('text-rose');
                        btn.classList.remove('text-text');
                    } else {
                        svg.setAttribute('fill', 'none');
                        btn.classList.add('text-text');
                        btn.classList.remove('text-rose');
                    }
                } else {
                    console.error('Failed to toggle like. Status:', response.status);
                }
            } catch (error) {
                console.error('Error:', error);
            }
        };
    }

    if (typeof toggleComment !== 'function') {
        window.toggleComment = function(logId) {
            const section = document.getElementById(`comments-section-${logId}`);
            section.style.display = section.style.display === 'none' ? 'block' : 'none';
        };

        window.toggleReplies = function(commentId) {
            const list = document.getElementById(`replies-list-${commentId}`);
            const textSpan = document.getElementById(`reply-toggle-text-${commentId}`);

            if (list.classList.contains('hidden')) {
                list.classList.remove('hidden');
                const count = textSpan.innerText.match(/\d+/)[0];
                textSpan.innerText = `Сховати відповіді (${count})`;
            } else {
                list.classList.add('hidden');
                const count = textSpan.innerText.match(/\d+/)[0];
                textSpan.innerText = `Показати відповіді (${count})`;
            }
        };

        window.setReplyContext = function(logId, parentCommentId, username) {
            document.getElementById(`parent-comment-id-${logId}`).value = parentCommentId;
            document.getElementById(`reply-to-name-${logId}`).innerText = '@@' + username;
            document.getElementById(`reply-badge-${logId}`).classList.remove('hidden');
            
            const input = document.getElementById(`comment-input-${logId}`);
            if (!input.value.startsWith(`@@`)) {
                input.value = `@@${username} ` + input.value;
            }
            input.focus();
        };

        window.cancelReply = function(logId) {
            document.getElementById(`parent-comment-id-${logId}`).value = '';
            document.getElementById(`reply-badge-${logId}`).classList.add('hidden');
            
            const input = document.getElementById(`comment-input-${logId}`);
            input.value = input.value.replace(/^@@\S+\s/, '');
        };

        window.submitComment = async function(logId) {
            const input = document.getElementById(`comment-input-${logId}`);
            const text = input.value.trim();
            if (!text) return;

            const parentIdInput = document.getElementById(`parent-comment-id-${logId}`)?.value;

            const formData = new FormData();
            formData.append('logId', logId);
            formData.append('text', text);
            if (parentIdInput) {
                formData.append('parentCommentId', parentIdInput);
            }

            try {
                const response = await fetch('/Logs/AddComment', {
                    method: 'POST',
                    body: formData
                });

                if (response.ok) {
                    const data = await response.json();
                    const titleHtml = data.title ? `<span class="text-accent font-bold text-[10px] -mt-0.5 mb-1">${data.title}</span>` : '';

                    if (data.parentCommentId) {
                        const repliesList = document.getElementById(`replies-list-${data.parentCommentId}`);
                        const replyHtml = `
                            <div class="flex items-start gap-2 bg-accent/20 transition-colors duration-1000">
                                <img src="${data.profilePicture}" alt="Avatar" class="w-6 h-6 rounded-full shrink-0 object-cover border border-secondary/20" />
                                <div class="flex flex-col flex-1">
                                    <div class="flex items-baseline gap-2">
                                        <strong class="text-text text-xs">${data.username}</strong>
                                        <span class="text-primary text-[10px]">${data.date}</span>
                                    </div>
                                    ${titleHtml}
                                    <div class="text-text text-sm">${data.text}</div>
                                </div>
                            </div>`;

                        repliesList.insertAdjacentHTML('beforeend', replyHtml);
                        repliesList.classList.remove('hidden');

                        const newReplyNode = repliesList.lastElementChild;
                        setTimeout(() => newReplyNode.classList.remove('bg-accent/20'), 2000);

                        let toggleText = document.getElementById(`reply-toggle-text-${data.parentCommentId}`);
                        if (!toggleText) {
                            const btnHtml = `
                                <button onclick="toggleReplies(${data.parentCommentId})" id="reply-toggle-btn-${data.parentCommentId}" class="text-xs text-secondary font-bold flex items-center gap-2 hover:text-text transition-colors mt-2">
                                    <span class="w-6 h-[1px] bg-secondary/50 block"></span>
                                    <span id="reply-toggle-text-${data.parentCommentId}">Сховати відповіді (1)</span>
                                </button>`;
                            repliesList.insertAdjacentHTML('beforebegin', btnHtml);
                        } else {
                            let match = toggleText.innerText.match(/\d+/);
                            let count = match ? parseInt(match[0]) + 1 : 1;
                            toggleText.innerText = `Сховати відповіді (${count})`;
                        }

                        if (typeof cancelReply === 'function') {
                            cancelReply(logId);
                        }

                    } else {
                        const list = document.getElementById(`comments-list-${logId}`);
                        const newCommentHtml = `
                            <div class="border-b border-secondary/20 py-3 last:border-0 bg-accent/20 transition-colors duration-1000" id="comment-container-${data.id}">
                                <div class="flex items-start gap-3">
                                    <img src="${data.profilePicture}" alt="Avatar" class="w-8 h-8 rounded-full shrink-0 object-cover border border-secondary/20" />
                                    <div class="flex flex-col flex-1">
                                        <div class="flex items-baseline gap-2">
                                            <strong class="text-text text-sm">${data.username}</strong>
                                            <span class="text-primary text-xs">${data.date}</span>
                                        </div>
                                        ${titleHtml}
                                        <div class="mt-0.5 text-text text-sm">${data.text}</div>
                                        <button onclick="setReplyContext(${logId}, ${data.id}, '${data.username}')" class="text-xs text-primary font-bold mt-1 text-left w-fit hover:text-accent transition-colors">Відповісти</button>
                                    </div>
                                </div>
                                <div class="ml-11 mt-1"><div id="replies-list-${data.id}" class="mt-3 space-y-3"></div></div>
                            </div>`;

                        list.insertAdjacentHTML('beforeend', newCommentHtml);
                        const newCommentNode = list.lastElementChild;
                        setTimeout(() => newCommentNode.classList.remove('bg-accent/20'), 2000);
                        list.scrollTop = list.scrollHeight;
                    }

                    input.value = '';
                    const countSpan = document.getElementById(`comment-count-${logId}`);
                    countSpan.innerText = parseInt(countSpan.innerText) + 1;
                }
            } catch (error)
            {
                console.error('Error:', error);
            }
        };
    }
</script>