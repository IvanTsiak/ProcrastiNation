@{
    ViewData["Title"] = "Налаштування";
}

<div class="max-w-2xl mx-auto bg-surface min-h-screen relative pb-12 shadow-sm rounded-xl overflow-hidden mt-0 border border-secondary/30">

    <div class="sticky top-0 z-50 bg-surface/90 backdrop-blur-md border-b border-secondary/30 px-4 py-3 flex items-center gap-4">
        <a asp-controller="Profile" asp-action="Index" class="btn btn-circle btn-ghost btn-sm text-text hover:bg-secondary/20">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
            </svg>
        </a>
        <h1 class="text-xl font-bold text-text mb-0">Налаштування</h1>
    </div>

    <div class="p-4 space-y-6">

        <div>
            <h2 class="text-xs font-bold text-primary uppercase tracking-widest mb-2 ml-2">Акаунт</h2>
            <div class="bg-background rounded-xl border border-secondary/30 overflow-hidden divide-y divide-secondary/20">

                <a href="#" class="flex items-center justify-between p-4 hover:bg-secondary/10 transition-colors group">
                    <div>
                        <p class="font-bold text-text">Редагувати профіль</p>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-primary group-hover:text-text transition-colors">
                        <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
                    </svg>
                </a>

            </div>
        </div>

        <div>
            <h2 class="text-xs font-bold text-primary uppercase tracking-widest mb-2 ml-2">Загальні</h2>
            <div class="bg-background rounded-xl border border-secondary/30 divide-y divide-secondary/20">

                <div class="flex items-center justify-between p-4">
                    <span class="font-bold text-text">Тема</span>
                    <label class="swap swap-rotate hover:cursor-pointer">
                        <input type="checkbox" class="theme-controller" value="synthwave" />
                        <svg class="swap-off h-8 w-8 fill-primary"
                             xmlns="http://www.w3.org/2000/svg"
                             viewBox="0 0 24 24">
                            <path d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z" />
                        </svg>
                        <svg class="swap-on h-8 w-8 fill-primary"
                             xmlns="http://www.w3.org/2000/svg"
                             viewBox="0 0 24 24">
                            <path d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z" />
                        </svg>
                    </label>
                </div>

                <div class="dropdown dropdown-end w-full group">

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success mb-4 rounded-xl shadow-sm text-sm font-bold">
                            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-5 w-5" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                            <span>@TempData["SuccessMessage"]</span>
                        </div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-error mb-4 rounded-xl shadow-sm text-sm font-bold text-white">
                            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-5 w-5" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                            <span>@TempData["ErrorMessage"]</span>
                        </div>
                    }

                    <div tabindex="0" role="button" class="flex items-center justify-between p-4 last:rounded-b-xl hover:bg-secondary/10 transition-colors w-full outline-none">
                        <span class="font-bold text-text">Дані записів (Excel)</span>

                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-primary group-hover:text-text transition-colors">
                            <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0l-4.25-4.25a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
                        </svg>
                    </div>

                    <ul tabindex="0" class="dropdown-content z-[100] menu p-2 shadow-xl bg-surface border border-secondary/30 rounded-box w-56 mt-2">
                        <li>
                            <form asp-action="Import" method="post" enctype="multipart/form-data" id="importForm" class="hidden">
                                <input type="file" id="fileExcel" name="fileExcel" accept=".xlsx" onchange="document.getElementById('importForm').submit();" />
                            </form>

                            <a href="#" onclick="document.getElementById('fileExcel').click(); return false;" class="text-text font-bold hover:bg-secondary/20">
                                Імпортувати дані
                            </a>
                        </li>
                        <li>
                            <a asp-action="Export" class="text-text font-bold hover:bg-secondary/20">
                                Експортувати дані
                            </a>
                        </li>
                    </ul>
                </div>

            </div>
        </div>

        <div>
            <h2 class="text-xs font-bold text-primary uppercase tracking-widest mb-2 ml-2">Інформація</h2>
            <div class="bg-background rounded-xl border border-secondary/30 overflow-hidden divide-y divide-secondary/20">

                <a href="#" class="flex items-center justify-between p-4 hover:bg-secondary/10 transition-colors group">
                    <span class="font-bold text-text">Політика конфіденційності</span>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-primary group-hover:text-text transition-colors">
                        <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
                    </svg>
                </a>

                <a href="#" class="flex items-center justify-between p-4 hover:bg-secondary/10 transition-colors group">
                    <div>
                        <p class="font-bold text-text">Контакти</p>
                        <p class="text-xs text-primary mt-0.5">Про нас, підтримка, соцмережі</p>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-primary group-hover:text-text transition-colors">
                        <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
                    </svg>
                </a>

            </div>
        </div>

        @if (User.IsInRole("Admin"))
        {
            <div>
                <h2 class="text-xs font-bold text-primary uppercase tracking-widest mb-2 ml-2">Для Адміністратора</h2>
                <div class="bg-background rounded-xl border border-secondary/30 overflow-hidden">
                    <div class="flex items-center justify-between p-4">
                        <div>
                            <span class="font-bold text-text">Панель адміністратора</span>
                        </div>
                        <input type="checkbox" id="adminFabToggle" class="checkbox border-text checked:bg-secondary" />
                    </div>
                </div>
            </div>
        }

        <div class="pt-4 pb-0">
            <a asp-controller="Account" asp-action="Logout" class="btn w-full bg-rose-100 hover:bg-rose-200 text-rose-600 border-none font-bold shadow-sm">
                Вийти з акаунта
            </a>
        </div>

    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const fabToggle = document.getElementById('adminFabToggle');
        if (!fabToggle) {
            return;
        }

        const adminFab = document.getElementById('adminFab');

        if (localStorage.getItem('showAdminFab') === 'true') {
            fabToggle.checked = true;
        }

        fabToggle.addEventListener('change', function() {
            if (this.checked) {
                localStorage.setItem('showAdminFab', 'true');
                if (adminFab) {
                    adminFab.classList.remove('hidden');
                }
            } else {
                localStorage.setItem('showAdminFab', 'false');
                if (adminFab) {
                    adminFab.classList.add('hidden');
                }
            }
        });
    });
</script>