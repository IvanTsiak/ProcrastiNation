@model ProcrastiInfrastructure.Models.GlobalStatsViewModel

@{
    ViewData["Title"] = "Зал слави";
}

<div class="banner">
    <h1 class="text-5xl font-black text-white drop-shadow-md tracking-tight">Зал слави</h1>
</div>

<div class="max-w-5xl mx-auto space-y-8">
    <div class="bg-surface border border-secondary/50 rounded-xl overflow-hidden shadow-sm">

        <div class="px-5 py-3 border-b border-secondary/50 bg-background/60">
            <h3 class="font-bold text-text text-base">Три найбільші прокрастинори</h3>
        </div>

        <div class="flex flex-col">
            @{
                int rank = 1;
            }
            @foreach (var user in Model.TopUsers)
            {
                string medal = rank == 1 ? "🥇" : rank == 2 ? "🥈" : rank == 3 ? "🥉" : "🏅";

                <div class="flex items-center gap-4 p-4 border-b border-secondary/20 last:border-0 hover:bg-background/40 transition-colors">

                    <div class="text-3xl w-10 text-center shrink-0 drop-shadow-sm">@medal</div>

                    <img src="@(string.IsNullOrEmpty(user.Profilepicture) ? "/images/avatars/default-avatar.png" : user.Profilepicture)"
                         alt="Аватар"
                         class="w-12 h-12 rounded-full object-cover shrink-0 border border-secondary/30 shadow-sm" />

                    <div class="flex flex-col flex-1">
                        <span class="font-extrabold text-text text-base">@(user.Username ?? "Анонім")</span>

                        @if (user.Title != null)
                        {
                            <span class="text-accent font-bold text-sm">@user.Title.Name</span>
                        }
                    </div>

                    <div class="text-right">
                        <div class="text-[11px] font-bold text-primary uppercase tracking-wider mb-0.5">Загалом витрачено</div>
                        <div class="text-text font-black text-lg">@user.Totalloss <span class="text-sm font-bold text-rose-500">хв</span></div>
                    </div>
                </div>
                rank++;
            }
        </div>
    </div>

    <div class="bg-surface border border-secondary/50 rounded-xl overflow-hidden shadow-sm">
        <div class="px-5 py-3 border-b border-secondary/50 bg-background/60">
            <h3 class="font-bold text-text text-base">На що ж люди витрачають свій час?</h3>
        </div>

        <div class="p-8 m-4 min-h-[300px] flex flex-col items-center justify-center border-2 border-dashed border-secondary/40 rounded-xl bg-background/30">
            @if (Model.TopActivities != null && Model.TopActivities.Any())
            {
                <canvas id="activitiesChart"></canvas>
            }
            else
            {
                <p class="text-primary font-bold">Поки що немає даних для графіка.</p>
            }
        </div>
    </div>

    <div class="bg-surface border border-secondary/50 rounded-xl overflow-hidden shadow-sm">
        <div class="px-5 py-3 border-b border-secondary/50 bg-background/60">
            <h3 class="font-bold text-text text-base">Проблеми, які найбільше сподобались іншим</h3>
        </div>

        <div class="flex flex-col">
            @foreach (var log in Model.TopComments)
            {
                <partial name="_LogCard" model="log" />
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const canvas = document.getElementById('activitiesChart');

            if (!canvas) {
                return;
            }

            const ctx = canvas.getContext('2d');

            const rootStyles = getComputedStyle(document.documentElement);
            const getColor = (name) => rootStyles.getPropertyValue(name).trim();

            const colorAccent = getColor('--color-accent');
            const colorText = getColor('--color-text');
            const colorPrimary = getColor('--color-primary');
            const colorSecondary = getColor('--color-secondary');

            const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopActivities.Select(a => a.Name)));
            const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopActivities.Select(a => a.Mentionscount)));

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Кількість згадок',
                        data: data,
                        backgroundColor: colorAccent,
                        borderColor: colorText,
                        borderWidth: 1,
                        borderRadius: 4,
                        barPercentage: 0.8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            backgroundColor: colorText,
                            titleFont: {
                                family: 'Inter',
                                size: 13
                            },
                            bodyFont: {
                                family: 'Inter',
                                size: 14,
                                weight: 'bold'
                            },
                            padding: 10,
                            cornerRadius: 8,
                            displayColors: false
                        }
                    },
                    scales: {
                        x: {
                            ticks: {
                                color: colorText,
                                font: {
                                    family: 'Inter',
                                    weight: '600',
                                    size: 13
                                }
                            },
                            grid: {
                                display: true
                            }
                        },
                        y: {
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: 'Кількість згадок',
                                color: colorText,
                                font: {
                                    family: 'Inter',
                                    size: 13,
                                    weight: '600'
                                },
                                padding: {
                                    bottom: 10
                                }
                            },
                            ticks: {
                                precision: 0,
                                color: colorPrimary,
                                font: {
                                    family: 'Inter',
                                    size: 12
                                }
                            },
                            grid: {
                                display: true
                            }
                        }
                    }
                }
            });
        });
    </script>
}