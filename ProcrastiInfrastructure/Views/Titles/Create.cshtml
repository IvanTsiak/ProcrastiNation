@model ProcrastiDomain.Model.Title

@{
    ViewData["Title"] = "Створити титул";
}

<div class="max-w-2xl mx-auto p-8 bg-surface border border-secondary/30 rounded-xl mt-6 shadow-sm">
    <div class="mb-6 border-b border-secondary/30 pb-4">
        <h1 class="text-2xl font-bold text-text">Створити титул</h1>
    </div>

    <form asp-action="Create" class="space-y-5">
        <div asp-validation-summary="ModelOnly" class="text-rose-500 text-sm font-semibold"></div>

        <div class="form-control">
            <label asp-for="Code" class="label pb-1"><span class="label-text font-bold text-text">Код титулу</span></label>
            <input asp-for="Code" class="input input-bordered w-full bg-background border-secondary/50 focus:border-text text-text" />
            <span asp-validation-for="Code" class="text-rose-500 text-xs mt-1"></span>
        </div>

        <div class="form-control">
            <label asp-for="Name" class="label pb-1"><span class="label-text font-bold text-text">Назва</span></label>
            <input asp-for="Name" class="input input-bordered w-full bg-background border-secondary/50 focus:border-text text-text" />
            <span asp-validation-for="Name" class="text-rose-500 text-xs mt-1"></span>
        </div>

        <div class="pt-4 flex items-center gap-4">
            <input type="submit" value="Створити" class="btn bg-text text-background hover:bg-text/80 border-none px-6" />
            <a asp-action="Index" class="text-sm font-medium text-primary hover:text-text">Скасувати</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}