@model IEnumerable<ProcrastiDomain.Model.Title>

@{
    ViewData["Title"] = "My Titles";
}

<div class="container mt-4">
    <h2>👑 My Titles</h2>
    <p class="text-muted">Choose a title to display next to your username.</p>
    <hr />

    <div class="row mt-4">
        @if (Model != null && Model.Any())
        {
            foreach (var title in Model)
            {
                bool isActive = ViewBag.ActiveTitleId == title.Id;

                <div class="col-md-4 mb-3">
                    <div class="card text-center @(isActive ? "border-warning shadow-sm" : "")" style="@(isActive ? "background-color: #fffde7;" : "")">
                        <div class="card-body">
                            <h5 class="card-title fw-bold" style="color: #2b1055;">@title.Name</h5>

                            @if (isActive)
                            {
                                <span class="badge bg-warning text-dark mt-2" style="font-size: 14px;">Equipped ✓</span>
                            }
                            else
                            {
                                <form asp-action="SetActive" method="post">
                                    <input type="hidden" name="titleId" value="@title.Id" />
                                    <button type="submit" class="btn btn-outline-primary mt-2">Equip Title</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info">
                    You haven't unlocked any titles yet. Keep procrastinating to earn some!
                </div>
            </div>
        }
    </div>

    <div class="mt-4">
        <a asp-controller="Profile" asp-action="Index" class="btn btn-secondary">← Back to Profile</a>
    </div>
</div>