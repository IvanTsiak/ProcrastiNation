@model ProcrastiDomain.Model.Title

@{
    ViewData["Title"] = "Видалити титул";
}

<div class="max-w-2xl mx-auto p-8 bg-surface border border-secondary/30 rounded-xl mt-6 shadow-sm">

    <div class="mb-6 p-4 bg-rose-50 border border-rose-200 rounded-lg">
        <h3 class="text-lg font-bold text-rose-700">Ви впевнені, що хочете видалити цей титул?</h3>
        <p class="text-rose-600 text-sm mt-1">Цю дію неможливо скасувати.</p>
    </div>

    <div class="bg-background border border-secondary/30 rounded-lg p-6 mb-6">
        <dl class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <dt class="font-bold text-text text-sm">Код</dt>
            <dd class="sm:col-span-2 text-primary">@Html.DisplayFor(model => model.Code)</dd>

            <dt class="font-bold text-text text-sm">Назва</dt>
            <dd class="sm:col-span-2 text-primary">@Html.DisplayFor(model => model.Name)</dd>

            <dt class="font-bold text-text text-sm">Унікальний?</dt>
            <dd class="sm:col-span-2 text-primary">@(Model.Isunique == true ? "Так" : "Ні")</dd>
        </dl>
    </div>

    <form asp-action="Delete" class="flex items-center gap-4">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Видалити назавжди" class="btn bg-rose-600 text-white hover:bg-rose-700 border-none" />
        <a asp-action="Index" class="text-sm font-medium text-primary hover:text-text">Скасувати</a>
    </form>
</div>