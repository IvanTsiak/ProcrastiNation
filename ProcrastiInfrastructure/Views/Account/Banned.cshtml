@{
    ViewData["Title"] = "Ви нам не подобаєтесь";
    Layout = "_LayoutGuest";
}

<div class="flex flex-col items-center justify-center text-center p-8 mt-20">
    <div class="text-8xl mb-6">🚫</div>
    <h1 class="text-4xl md:text-5xl font-black text-text mb-4 tracking-tighter">
        Ви нам не подобаєтесь
    </h1>
    <p class="text-xl text-primary max-w-xl mb-8 font-medium leading-relaxed">
        Ваш акаунт заблоковано, бо ви не припали адмінам до душі.
    </p>

    <a asp-controller="Account" asp-action="Logout" class="btn bg-rose hover:bg-rose-600 text-white border-none font-bold rounded-xl px-8 py-3 transition-all duration-200 shadow-lg shadow-rose/20">
        Вийти з акаунта
    </a>
</div>