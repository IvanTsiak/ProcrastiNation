@model ProcrastiInfrastructure.Models.AchievementsViewModel;

@{
    ViewData["Title"] = "Досягнення";
}

<div class="mb-6">
    <h2 class="text-2xl font-bold text-text mb-1">Досягнення, за які не соромно</h2>
    <p class="text-sm font-semibold text-primary">Зібрано: @Model.EarnedCount / @Model.TotalCount</p>
</div>

<div class="border-b border-secondary/40 mb-8"></div>

<div class="flex flex-wrap gap-6">
    @foreach (var achievement in Model.Achievements)
    {
        bool isRickroll = achievement.Title == "Rick Astley";

        string cardStateClass = achievement.IsUnlocked
            ? "border-accent bg-background shadow-sm"
            : "border-secondary/40 bg-secondary/10 grayscale opacity-60";

        string cursorClass = isRickroll ? "cursor-pointer" : "";

        <div class="card w-60 border-2 transition-all duration-300 hover:-translate-y-1 @cardStateClass @cursorClass"
            @(isRickroll ? "onclick=triggerRickroll(this)" : "")>
            
            <div class="card-body p-5 items-center text-center">
                <div class="w-24 h-24 bg-secondary rounded-xl mb-2 flex items-center justify-center overflow-hidden">
                    @if (!string.IsNullOrEmpty(achievement.Icon))
                    {
                        <img src="@achievement.Icon" alt="@achievement.Title" class="w-full h-full object-cover object-center" />
                    }
                    else
                    {
                        <img src="/images/achievements/default-icon.png" alt="@achievement.Title" class="w-full h-full object-cover object-center" />
                    }
                </div>

                <h4 class="card-title text-base font-bold text-text mt-2">@achievement.Title</h4>
                <p class="text-sm text-primary">@Html.Raw(achievement.Description)</p>

                <div class="mt-4 w-full border-t border-secondary/20 pt-3">
                    @if (achievement.IsUnlocked)
                    {
                        <p class="text-accent font-bold text-sm uppercase tracking-wider">Unlocked</p>
                    }
                    else
                    {
                        <p class="text-primary italic text-sm">Locked</p>
                    }
                </div>

            </div>
        </div>
    }
</div>