    const lineChars = 96;
    const lines = 36;
    const frameSize = lineChars * lines;
    const numFrames = 149;
    const frameTime = 120;

    let currentFrame = 0;
    let animationInterval;
    const display = document.getElementById('ascii-display');
    const startScreen = document.getElementById('start-screen');
    const audio = document.getElementById('rickroll-audio');

    function drawNextFrame() {
            if (currentFrame >= numFrames) {
                currentFrame = 0;
            }

            let frameText = "";
            let startIndex = currentFrame * frameSize;

            if (startIndex + frameSize <= frames.length) {
                for (let i = 0; i < frameSize; i++) {
                    frameText += String.fromCharCode(frames[startIndex + i]);
                }
                display.innerText = frameText;
            }
            
            currentFrame++;
        }

        document.body.addEventListener('click', function() {
            startScreen.style.display = 'none';
            display.style.display = 'block';
            
            audio.play();

            if (!animationInterval) {
                animationInterval = setInterval(drawNextFrame, frameTime);
            }
        });

    </script>
