@{
    ViewData["Title"] = "Секретна гра";
}

<style>
    .snake-game-area {
        width: 100%;
        display: flex;
        justify-content: center;
    }

    .wrapper {
        width: 100%;
        max-width: 400px;
        aspect-ratio: 1 / 1;
        display: flex;
        flex-direction: column;
        border-radius: 8px;
        background-color: #193447;
        overflow: hidden;
    }

    .play-board {
        width: 100%;
        height: 100%;
        display: grid;
        grid-template-rows: repeat(30, 1fr);
        grid-template-columns: repeat(30, 1fr);
        background-color: #212837;
    }

        .play-board .food {
            background-color: #ff003d;
            border-radius: 50%;
        }

        .play-board .head {
            background-color: #B8C6DC;
        }

        .play-board .body {
            background-color: #4CAF50;
        }
</style>

<div class="max-w-5xl mx-auto mt-6 mb-12 px-4 flex flex-col md:flex-row gap-8 items-center md:items-start">

    <div class="w-full md:w-1/2 flex flex-col items-center bg-surface border border-secondary/50 rounded-xl p-6 shadow-sm">
        <h2 class="text-3xl font-black text-text mb-6 drop-shadow-sm tracking-tight">Поглинач часу</h2>

        <div class="snake-game-area">
            <div class="wrapper">
                <div class="play-board"></div>
            </div>
        </div>

        <div class="mt-8 text-center w-full">
            <a href="/Achievements" class="btn btn-ghost text-primary hover:text-background font-bold">← Назад до досягнень</a>
        </div>
    </div>

    <div class="w-full md:w-1/2 flex flex-col gap-6 mt-4 md:mt-0">

        <div class="bg-surface border border-secondary/50 rounded-xl p-6 shadow-sm">
            <span id="game-status-title" class="text-text font-bold text-lg mb-4 block">Виберіть складність:</span>

            <div id="difficulty-controls" class="flex flex-wrap gap-2">
                <button class="btn bg-emerald-500 hover:bg-emerald-600 text-white border-none" onclick="startGame('easy')">Легко</button>
                <button class="btn bg-amber-500 hover:bg-amber-600 text-white border-none" onclick="startGame('medium')">Нормально</button>
                <button class="btn bg-rose-500 hover:bg-rose-600 text-white border-none" onclick="startGame('hard')">Швидко-швидко</button>
            </div>
        </div>

        <div class="flex gap-4">
            <div class="bg-surface border border-secondary/50 rounded-xl p-4 shadow-sm flex-1 flex flex-col items-center justify-center">
                <span class="text-text font-bold text-xs uppercase tracking-widest opacity-70">Рахунок</span>
                <span id="score-display" class="text-3xl font-black text-accent mt-1">0</span>
            </div>
            <div class="bg-surface border border-secondary/50 rounded-xl p-4 shadow-sm flex-1 flex flex-col items-center justify-center">
                <span class="text-text font-bold text-xs uppercase tracking-widest opacity-70">Рекорд</span>
                <span id="highscore-display" class="text-3xl font-black text-emerald-500 mt-1">0</span>
            </div>
            <div class="bg-surface border border-secondary/50 rounded-xl p-4 shadow-sm flex-1 flex flex-col items-center justify-center">
                <span class="text-text font-bold text-xs uppercase tracking-widest opacity-70">Секунд</span>
                <span id="time-display" class="text-3xl font-black text-rose-500 mt-1">0</span>
            </div>
        </div>

        <div class="bg-surface border border-secondary/50 rounded-xl overflow-hidden shadow-sm">
            <div class="px-5 py-3 border-b border-secondary/50 bg-background/60">
                <h3 class="font-bold text-text text-base">Моя думка про вас</h3>
            </div>
            <div class="p-6 flex flex-col items-center text-center">
                <div id="snarky-comment" class="text-base text-text italic min-h-[60px] flex items-center justify-center transition-all duration-300">
                    Чекаю, поки почнеш марнувати час...
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    const playBoard = document.querySelector(".play-board");
    const scoreDisplay = document.getElementById("score-display");
    const highscoreDisplay = document.getElementById("highscore-display");
    const timeDisplay = document.getElementById("time-display");

    const gameStatusTitle = document.getElementById("game-status-title");
    const difficultyControls = document.getElementById("difficulty-controls");
    const snarkyComment = document.getElementById("snarky-comment");

    let foodX, foodY;
    let snakeX = 5, snakeY = 10;
    let snakeBody = [];
    let velocityX = 0, velocityY = 0;
    let score = 0;
    let secondsWasted = 0;
    let highScore = localStorage.getItem("snakeHighScore") || 0;

    let gameInterval;
    let timerInterval;
    let GameOver = false;
    let gameSpeed = 125;

    highscoreDisplay.textContent = highScore;

    const snarkyPhrases = [
        "Ого, ти з'їв піксель. Досягнення.",
        "Дедлайни горять, а змійка росте.",
        "Твоя продуктивність зараз десь у мінусі.",
        "Продовжуй, продовжуй. Роботодавець оцінить.",
        "З'їв ще одне яблуко, а міг би прочитати сторінку книги.",
        "Я не знаю, що гірше — витрачати час на це чи на Тік-ток",
        "Тобі аж так нудно, що ти граєш у це?",
        "Змійка росте, а твоє життя скорочується.",
        "Скільки літ, скільки зим, а ти все ще тут..."
    ];

    const changeFoodPosition = () => {
        foodX = Math.floor(Math.random() * 30) + 1;
        foodY = Math.floor(Math.random() * 30) + 1;
    }

    const changeDirection = (e) => {
        if(["ArrowUp","ArrowDown","ArrowLeft","ArrowRight"].includes(e.code)) {
            e.preventDefault();
        }

        if (e.key === "ArrowUp" && velocityY !== 1) { velocityX = 0; velocityY = -1; }
        else if (e.key === "ArrowDown" && velocityY !== -1) { velocityX = 0; velocityY = 1; }
        else if (e.key === "ArrowRight" && velocityX !== -1) { velocityX = 1; velocityY = 0; }
        else if (e.key === "ArrowLeft" && velocityX !== 1) { velocityX = -1; velocityY = 0; }
    }

    const gameOver = () => {
        clearInterval(gameInterval);
        clearInterval(timerInterval);
        GameOver = true;

        gameStatusTitle.innerText = "Гру закінчено! Зіграємо ще?";
        difficultyControls.style.display = "flex";

        snarkyComment.innerHTML = `<span class="text-rose-500 font-bold">ВРІЗАВСЯ!</span> Ти згаяв ${secondsWasted} секунд свого життя.`;
    }

    window.startGame = (difficulty) => {
        switch (difficulty) {
            case 'easy': gameSpeed = 200; break;
            case 'medium': gameSpeed = 125; break;
            case 'hard': gameSpeed = 75; break;
        }

        snakeX = 5; snakeY = 10;
        snakeBody = [];
        velocityX = 0; velocityY = 0;
        score = 0;
        secondsWasted = 0;
        GameOver = false;

        scoreDisplay.textContent = score;
        timeDisplay.textContent = secondsWasted;

        difficultyControls.style.display = "none";
        gameStatusTitle.innerText = "Процес деградації запущено (керуй стрілочками)...";
        snarkyComment.innerText = "Поїхали! Час пішов у нікуди.";

        changeFoodPosition();

        clearInterval(gameInterval);
        clearInterval(timerInterval);

        gameInterval = setInterval(initGame, gameSpeed);

        timerInterval = setInterval(() => {
            if(!GameOver) {
                secondsWasted++;
                timeDisplay.textContent = secondsWasted;

                if(secondsWasted % 30 === 0) {
                    snarkyComment.innerText = `Пройшло вже ${secondsWasted} секунд... Тобі реально нема чим зайнятися?`;
                }

                if(secondsWasted === 300) {
                    if (typeof tryUnlockAchievement === 'function') {
                        tryUnlockAchievement("SNAKE_LOVER");
                    }
                    snarkyComment.innerHTML = "<span class='text-emerald-500 font-bold'>5 хвилин!?</span> Ти серйозно? Ачівка твоя, але якою ціною...";
                }
            }
        }, 1000);
    }

    const initGame = () => {
        let tailX = snakeBody.length ? snakeBody[snakeBody.length - 1][0] : snakeX;
        let tailY = snakeBody.length ? snakeBody[snakeBody.length - 1][1] : snakeY;

        snakeX += velocityX;
        snakeY += velocityY;

        if (snakeX < 1 || snakeX > 30 || snakeY < 1 || snakeY > 30) {
            return gameOver();
        }

        for (let i = 0; i < snakeBody.length; i++) {
            if (snakeX === snakeBody[i][0] && snakeY === snakeBody[i][1]) {
                return gameOver();
            }
        }

        if (snakeX === foodX && snakeY === foodY) {
            changeFoodPosition();
            snakeBody.push([tailX, tailY]);
            score++;

            if (score > highScore) {
                highScore = score;
                localStorage.setItem("snakeHighScore", highScore);
            }

            scoreDisplay.textContent = score;
            highscoreDisplay.textContent = highScore;

            snarkyComment.innerText = snarkyPhrases[Math.floor(Math.random() * snarkyPhrases.length)];
        }

        for (let i = snakeBody.length - 1; i > 0; i--) {
            snakeBody[i] = snakeBody[i - 1];
        }

        if (snakeBody.length > 0) {
            snakeBody[0] = [snakeX - velocityX, snakeY - velocityY];
        }

        let htmlMarkup = `<div class="food" style='grid-area: ${foodY} / ${foodX}'></div>`;
        htmlMarkup += `<div class="head" style='grid-area: ${snakeY} / ${snakeX}'></div>`;

        for (let i = 0; i < snakeBody.length; i++) {
            htmlMarkup += `<div class="body" style='grid-area: ${snakeBody[i][1]} / ${snakeBody[i][0]}'></div>`;
        }

        if(playBoard) {
            playBoard.innerHTML = htmlMarkup;
        }
    }

    document.addEventListener('keydown', (e) => {
        if(!GameOver) {
            changeDirection(e);
        }
    });

    document.addEventListener("DOMContentLoaded", () => {
        if (typeof tryUnlockAchievement === 'function') {
            tryUnlockAchievement("SNAKE_FINDER");
        }
    });
</script>