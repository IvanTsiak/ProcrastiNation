@model ProcrastiDomain.Model.Log

@{
    ViewData["Title"] = "Створити запис";
}

<div class="max-w-2xl mx-auto mt-0 p-8 bg-background border border-secondary/40 rounded-2xl shadow-sm">
    <h1 class="text-3xl font-black text-text mb-6 tracking-tight">Створення запису</h1>
    <div class="border-b border-secondary/40 mb-6"></div>

    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-rose mb-4 text-sm font-semibold"></div>

        <div class="form-control mb-6 flex flex-col gap-2 items-start">
            <span class="font-bold text-text text-base">Як пройшла прокрастинація?</span>

            <label class="cursor-pointer inline-flex items-center gap-3">
                <span class="font-bold text-emerald text-sm uppercase tracking-wider">Чудово</span>
                <input type="checkbox" id="visualToggle" class="toggle bg-emerald border-emerald checked:bg-rose checked:border-rose" checked />
                <span class="font-bold text-rose text-sm uppercase tracking-wider">Марно</span>
            </label>

            <input type="hidden" asp-for="Logtype" id="hiddenLogType" value="loss" />
            <span asp-validation-for="Logtype" class="text-rose text-xs"></span>
        </div>

        <div class="form-control mb-6">
            <label class="label pb-1">
                <span class="label-text font-bold text-text text-base">Де ви витрачали свій час?</span>
            </label>
            <input name="activityName" list="verifiedActivities" placeholder="Виберіть або напишіть нове..." required autocomplete="off"
                   class="input input-bordered w-full bg-transparent border-secondary/50 focus:border-accent focus:outline-none text-text" />
            <span class="text-rose text-xs mt-1">@Html.ValidationMessage("activityName")</span>

            <datalist id="verifiedActivities">
                @if (ViewBag.VerifiedActivityNames != null)
                {
                    foreach (var name in ViewBag.VerifiedActivityNames)
                    {
                        <option value="@name"></option>
                    }
                }
            </datalist>
        </div>

        <div class="form-control mb-6">
            <label class="label pb-1">
                <span class="label-text font-bold text-text text-base">Скільки хвилин витратили?</span>
            </label>
            <input asp-for="Amount" type="number" min="1"
                   class="input input-bordered w-full bg-transparent border-secondary/50 focus:border-accent focus:outline-none text-text" />
            <span asp-validation-for="Amount" class="text-rose text-xs mt-1"></span>
        </div>

        <div class="form-control mb-6 flex flex-col gap-2 items-start">
            <label asp-for="Rating" class="font-bold text-text text-base">Оцініть витрачений час</label>

            <div class="rating rating-lg gap-1">
                <input type="radio" name="Rating" value="1" class="mask mask-star-2 bg-amber-400" />
                <input type="radio" name="Rating" value="2" class="mask mask-star-2 bg-amber-400" />
                <input type="radio" name="Rating" value="3" class="mask mask-star-2 bg-amber-400" checked="checked" />
                <input type="radio" name="Rating" value="4" class="mask mask-star-2 bg-amber-400" />
                <input type="radio" name="Rating" value="5" class="mask mask-star-2 bg-amber-400" />
            </div>

            <span asp-validation-for="Rating" class="text-rose text-xs"></span>
        </div>

        <div class="form-control mb-8 flex flex-col gap-2 items-stretch">
            <label asp-for="Comment" class="font-bold text-text text-base">Коментар</label>

            <textarea asp-for="Comment" placeholder="Для прикладу: Я знову дивився Тік-ток..."
                      class="textarea textarea-bordered h-28 w-full bg-transparent border-secondary/50 focus:border-accent focus:outline-none text-text text-base leading-relaxed resize-none"></textarea>

            <span asp-validation-for="Comment" class="text-rose text-xs"></span>
        </div>

        <div class="flex items-center gap-4 pt-2 border-t border-secondary/40 mt-6 pt-6">
            <button type="submit" class="btn bg-accent hover:bg-accent/80 text-background border-none font-bold px-8">Зберегти</button>
            <a asp-controller="Logs" asp-action="CancelCreation" class="btn btn-ghost text-primary hover:text-text hover:bg-secondary/20 font-semibold">Передумав ділитись</a>
        </div>
    </form>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const visualToggle = document.getElementById('visualToggle');
            const hiddenLogType = document.getElementById('hiddenLogType');

            visualToggle.addEventListener('change', function() {
                hiddenLogType.value = this.checked ? 'loss' : 'win';
            });
        });
        const NUM_OF_FAILS = 5;
        let validationFailCount = 0;

        $("form").on("submit", function (e) {
            if (!$(this).valid()) {
                validationFailCount++;
                
                if (validationFailCount === NUM_OF_FAILS) {
                    if (typeof tryUnlockAchievement == 'function') {
                        tryUnlockAchievement("INTELLECTUAL");
                    }
                }
            }
        });
    </script>
}