@model IEnumerable<ProcrastiDomain.Model.User>

@{
    ViewData["Title"] = "Керування користувачами";
}

<div class="max-w-6xl mx-auto p-6 bg-surface border border-secondary/30 rounded-xl mt-6 shadow-sm">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-text">Користувачі</h1>
        <p class="text-sm text-primary">Хто не подобається — в бан</p>
    </div>

    <div class="overflow-x-auto">
        <table class="table w-full border-collapse">
            <thead>
                <tr class="border-b-2 border-secondary/50 text-text">
                    <th class="py-3 px-4 text-left">Нікнейм</th>
                    <th class="py-3 px-4 text-left">Згаяно хв.</th>
                    <th class="py-3 px-4 text-left">Поточний титул</th>
                    <th class="py-3 px-4 text-center">Статус</th>
                    <th class="py-3 px-4 text-right">Дії</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-background/50 border-b border-secondary/20 transition-colors">
                        <td class="py-3 px-4 text-text font-bold">@item.Username</td>
                        <td class="py-3 px-4 text-rose font-medium">@(item.Totalloss ?? 0)</td>
                        <td class="py-3 px-4 text-accent text-sm">@(item.Title?.Name ?? "Немає")</td>

                        <td class="py-3 px-4 text-center">
                            @if (item.Isbanned == true)
                            {
                                <span class="bg-rose-100 text-rose-700 px-2 py-1 rounded text-xs font-bold uppercase">Заблоковано</span>
                            }
                            else
                            {
                                <span class="bg-emerald-100 text-emerald-700 px-2 py-1 rounded text-xs font-bold uppercase">Активний</span>
                            }
                        </td>

                        <td class="py-3 px-4 text-right">
                            <div class="flex justify-end items-center gap-3">
                                <a asp-action="AwardTitle" asp-route-id="@item.Id" class="text-xs font-bold text-amber-500 hover:text-amber-600 hover:underline">
                                    Нагородити
                                </a>


                                <span class="text-secondary/50">|</span>

                                <form asp-action="ToggleBlock" asp-route-id="@item.Id" method="post" class="m-0 p-0 inline">
                                    <button type="submit" class="text-xs font-bold @(item.Isbanned == true ? "text-emerald-600 hover:text-emerald-700" : "text-rose-600 hover:text-rose-700") hover:underline cursor-pointer bg-transparent border-none p-0">
                                        @(item.Isbanned == true ? "Розблокувати" : "Заблокувати")
                                    </button>
                                </form>

                                <span class="text-secondary/50">|</span>

                                <a asp-action="SendNotification" asp-route-id="@item.Id" class="text-xs font-bold text-accent hover:text-text transition-colors hover:underline">
                                    Написати
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>