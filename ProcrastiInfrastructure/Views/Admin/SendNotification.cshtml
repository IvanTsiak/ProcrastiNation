@model ProcrastiDomain.Model.User

@{
    ViewData["Title"] = "Надіслати сповіщення";
}

<div class="max-w-2xl mx-auto p-8 bg-surface border border-secondary/30 rounded-xl mt-10 shadow-sm">
    <div class="mb-6 border-b border-secondary/30 pb-4">
        <h1 class="text-2xl font-bold text-text">Написати повідомлення</h1>
        <p class="text-sm text-primary mt-1">Одержувач: <span class="font-bold text-accent">@Model.Username</span></p>
    </div>

    <form asp-action="SendNotification" method="post" class="space-y-6">
        <input type="hidden" name="userId" value="@Model.Id" />

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="bg-rose-100 text-rose-700 p-3 rounded text-sm font-bold">
                @Html.ValidationSummary(false)
            </div>
        }

        <div class="form-control">
            <label class="label px-0">
                <span class="label-text font-bold text-text">Заголовок</span>
            </label>
            <input type="text" name="title" class="w-full bg-background border border-secondary/50 p-3 rounded focus:outline-none focus:border-accent text-text transition-colors" placeholder="Наприклад: Останнє попередження!" />
        </div>

        <div class="form-control">
            <label class="label px-0">
                <span class="label-text font-bold text-text">Текст сповіщення</span>
            </label>
            <textarea name="message" class="w-full bg-background border border-secondary/50 p-3 rounded focus:outline-none focus:border-accent text-text h-32 resize-none transition-colors" placeholder="Що ви хочете сказати цьому користувачу?" required></textarea>
        </div>

        <div class="flex items-center gap-5 pt-4 border-t border-secondary/30">
            <button type="submit" class="bg-primary text-background px-6 py-2.5 rounded font-bold hover:bg-text transition-colors">Надіслати</button>
            <a asp-action="Users" class="text-primary hover:text-accent font-bold transition-colors">Скасувати</a>
        </div>
    </form>
</div>