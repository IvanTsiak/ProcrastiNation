@model IEnumerable<ProcrastiDomain.Model.Log>

@{
    ViewData["Title"] = "Модерація записів";
}

<div class="max-w-4xl mx-auto space-y-6 mt-8">

    <div class="flex items-center justify-between bg-surface border border-secondary/50 p-6 rounded-xl shadow-sm">
        <div>
            <h1 class="text-2xl font-black text-text mb-1">Модерація записів</h1>
        </div>
    </div>

    <div class="main-div">
        @if (Model.Any())
        {
            <div class="flex flex-col divide-y divide-secondary/40">
                @foreach (var log in Model)
                {
                    <div class="relative group">
                        <div class="pointer-events-none opacity-80">
                            <partial name="_LogCard" model="log" />
                        </div>

                        <div class="p-4 bg-background/50 border-t border-secondary/20 flex items-center justify-end gap-4">

                            <form asp-action="ApproveLog" asp-route-id="@log.Id" method="post">
                                <button type="submit" class="btn btn-sm bg-emerald text-background border-none hover:bg-emerald/80 font-bold shadow-sm">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 mr-1">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                                    </svg>
                                    Показувати іншим
                                </button>
                            </form>

                            <form asp-action="DeleteLog" asp-route-id="@log.Id" method="post" onsubmit="return confirm('Ти впевнений, що хочеш видалити цей запис повністю? Тригери БД перерахують статистику.');">
                                <button type="submit" class="btn btn-sm bg-rose-100 text-rose border-none hover:bg-rose-200 font-bold shadow-sm">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 mr-1">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                                    </svg>
                                    Видалити
                                </button>
                            </form>

                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="p-12 text-center flex flex-col items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-16 h-16 text-primary/50 mb-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
                <p class="text-lg font-bold text-text mb-1">Підозрілі записи або перевірені, або їх з'їв вовк</p>
            </div>
        }
    </div>
</div>