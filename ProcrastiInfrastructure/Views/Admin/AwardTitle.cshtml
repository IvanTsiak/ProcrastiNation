@model ProcrastiDomain.Model.User

@{
    ViewData["Title"] = "Створити унікальний титул";
}

<div class="max-w-2xl mx-auto p-8 bg-surface border border-secondary/30 rounded-xl mt-6 shadow-sm">
    <div class="mb-6 border-b border-secondary/30 pb-4">
        <h1 class="text-2xl font-bold text-text">Унікальний титул</h1>
        <p class="text-primary mt-2">І щасливчиком його отримати є: <span class="font-black text-accent text-lg">@Model.Username</span></p>
    </div>

    <form asp-action="AwardTitle" class="space-y-5">
        <div asp-validation-summary="ModelOnly" class="text-rose text-sm font-semibold"></div>
        <input type="hidden" name="userId" value="@Model.Id" />

        <div class="form-control">
            <label class="label pb-1"><span class="label-text font-bold text-text">Код</span></label>
            <input type="text" name="titleCode" class="input input-bordered w-full bg-background border-secondary/50 focus:border-text text-text"/>
        </div>

        <div class="form-control">
            <label class="label pb-1"><span class="label-text font-bold text-text">Назва</span></label>
            <input type="text" name="titleName" class="input input-bordered w-full bg-background border-secondary/50 focus:border-text text-text" required placeholder="Тільки давай щось нормальне" />
        </div>

        <div class="pt-4 flex items-center gap-4">
            <button type="submit" class="btn bg-amber-500 text-white hover:bg-amber-600 border-none px-6 shadow-sm">
                Подарувати титул
            </button>
            <a asp-controller="Home" asp-action="Index" class="text-sm font-medium text-primary hover:text-text">Скасувати</a>
        </div>
    </form>
</div>