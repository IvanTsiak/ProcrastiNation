                        <path d="M10 12.5C11.3807 12.5 12.5 11.3807 12.5 10C12.5 8.61929 11.3807 7.5 10 7.5C8.61929 7.5 7.5 8.61929 7.5 10C7.5 11.3807 8.61929 12.5 10 12.5Z" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </a>
            </div>
        }

        <img src="@(string.IsNullOrEmpty(Model.ProfilePicture) ? "/images/avatars/default-avatar.png" : Model.ProfilePicture)"
             alt="Avatar"
             class="w-28 h-28 rounded-full object-cover border-4 border-background shadow-md shrink-0" />

        <div class="flex flex-col">
            <h2 class="text-3xl font-black text-text">@Model.Username</h2>
            <span class="text-accent font-bold text-base mt-1 tracking-wide">
                @(string.IsNullOrEmpty(Model.CurrentTitle) ? "Нема титулу" : Model.CurrentTitle)
            </span>
            <span class="text-primary text-sm mt-3 italic">
                Почав вести облік страждань з @Model.JoinedDate?.ToString("dd.MM.yyyy")
            </span>
        </div>
    </div>

    <div class="grid grid-cols-3 gap-4">

        <div class="bg-accent/10 border border-accent/30 rounded-xl p-5 flex flex-col items-center justify-center shadow-sm text-center">
            <svg width="28" height="28" viewBox="0 0 24 24" class="fill-secondary/70" xmlns="http://www.w3.org/2000/svg">
                <path d="M14.059 16H15C21.643 16 24 12.5 24 9.5C23.9978 8.67514 23.7043 7.87757 23.1713 7.24801C22.6384 6.61844 21.9002 6.19734 21.087 6.05901C21.4638 5.27186 21.7503 4.4446 21.941 3.593C22.0298 3.1607 22.0208 2.71401 21.9148 2.28561C21.8087 1.85721 21.6082 1.45794 21.328 1.117C21.0441 0.767409 20.6857 0.48568 20.2789 0.292419C19.8722 0.0991583 19.4273 -0.000748534 18.977 4.22236e-06H5.023C4.57266 -0.000748534 4.12784 0.0991583 3.72108 0.292419C3.31431 0.48568 2.95588 0.767409 2.672 1.117C2.39176 1.45794 2.19128 1.85721 2.08521 2.28561C1.97915 2.71401 1.9702 3.1607 2.059 3.593C2.25001 4.44457 2.53579 5.27206 2.911 6.06001C2.09835 6.19874 1.36076 6.61987 0.828222 7.24919C0.295681 7.87851 0.00237578 8.67561 0 9.5C0 12.5 2.357 16 9 16H9.933C9.97044 16.2105 9.99283 16.4233 10 16.637V20C10.0172 20.2671 9.97723 20.5348 9.88279 20.7852C9.78836 21.0357 9.64162 21.2631 9.45237 21.4524C9.26311 21.6416 9.03568 21.7884 8.78524 21.8828C8.53479 21.9772 8.2671 22.0172 8 22H5V24H19V22H16C15.7323 22.018 15.4639 21.9788 15.2126 21.8847C14.9614 21.7907 14.7331 21.6441 14.543 21.4548C14.3529 21.2655 14.2054 21.0378 14.1104 20.7869C14.0154 20.536 13.975 20.2677 13.992 20V16.637C13.9997 16.4234 14.022 16.2105 14.059 16ZM15.477 13.349C17.2848 11.834 18.825 10.0258 20.033 8H20.5C20.8978 8 21.2794 8.15804 21.5607 8.43934C21.842 8.72065 22 9.10218 22 9.5C22 11.676 20.008 14 14.847 14C15.0287 13.7573 15.2404 13.5386 15.477 13.349ZM2 9.5C2 9.10218 2.15804 8.72065 2.43934 8.43934C2.72064 8.15804 3.10218 8 3.5 8H3.964C5.16964 10.0261 6.7082 11.8344 8.515 13.349C8.75109 13.5391 8.96271 13.7578 9.145 14C3.984 14 2 11.676 2 9.5Z"/>
            </svg>
            <span class="text-3xl font-black text-text">@Model.AchievementsCount</span>
            <span class="text-xs font-bold text-primary uppercase mt-1">Досягнень</span>
        </div>

        <div class="bg-accent/10 border border-accent/30 rounded-xl p-5 flex flex-col items-center justify-center shadow-sm text-center">
            <svg width="28" height="22" class="fill-secondary/70" viewBox="0 0 14 11" xmlns="http://www.w3.org/2000/svg">
                <path d="M13.5 2.5L10.5 5.5L7 0.5L3.5 5.5L0.5 2.5V9C0.5 9.39782 0.658035 9.77936 0.93934 10.0607C1.22064 10.342 1.60218 10.5 2 10.5H12C12.3978 10.5 12.7794 10.342 13.0607 10.0607C13.342 9.77936 13.5 9.39782 13.5 9V2.5Z" />
            </svg>
            <span class="text-3xl font-black text-text">@Model.TitlesCount</span>
            <span class="text-xs font-bold text-primary uppercase mt-1">Титулів</span>
        </div>

        <div class="bg-accent/10 border border-accent/30 rounded-xl p-5 flex flex-col items-center justify-center shadow-sm text-center">
            <svg width="21" height="28" viewBox="0 0 18 24" class="fill-secondary/70" xmlns="http://www.w3.org/2000/svg">
                <path d="M12.624 19H5.383C6.17153 17.2646 7.42955 15.7842 9.015 14.726C10.5979 15.7807 11.8493 17.2627 12.624 19ZM18 21V24H0V21C0.0597974 19.2706 0.486796 17.5738 1.25265 16.0221C2.0185 14.4704 3.10567 13.0993 4.442 12C3.10567 10.9007 2.0185 9.52964 1.25265 7.97794C0.486796 6.42624 0.0597974 4.72937 0 3C0 2.20435 0.316071 1.44129 0.87868 0.87868C1.44129 0.31607 2.20435 0 3 0L15 0C15.7956 0 16.5587 0.31607 17.1213 0.87868C17.6839 1.44129 18 2.20435 18 3C17.941 4.72779 17.516 6.4234 16.7532 7.97482C15.9905 9.52624 14.9072 10.8982 13.575 12C14.9072 13.1018 15.9905 14.4738 16.7532 16.0252C17.516 17.5766 17.941 19.2722 18 21ZM14.91 19.845C14.349 16.279 11.317 13.822 9.561 12.676L9.012 12.317L8.465 12.677C6.7 13.833 3.659 16.3 3.092 19.842L2.907 21H15.092L14.91 19.845Z"/>
            </svg>
            <span class="text-3xl font-black text-text">@Model.TotalLoss</span>
            <span class="text-xs font-bold text-primary uppercase mt-1">Витрачено хвилин</span>
        </div>

    </div>

    <div class="main-div">
        <div class="m-div-header">
            <h3 class="main-h3">Останні записи</h3>

            @if (Model.IsCurrentUser)
            {
                <a asp-action="AllLogs" class="text-xs font-bold text-primary hover:text-accent transition-colors tracking-wider">
                    Переглянути всі
                </a>
            }
        </div>

        <div class="flex flex-col">
            @if (Model.RecentLogs.Any())
            {
                foreach (var log in Model.RecentLogs)
                {
                    <partial name="_LogCard" model="log" />
                }
            }
            else
            {
                <div class="p-8 text-center text-primary font-bold">І досі не створив жодного запису!?</div>
            }
        </div>
    </div>

    <div class="main-div">
        <div class="m-div-header">
            <h3 class="main-h3">Невтішний графік витрат за місяць</h3>
        </div>

        <div class="p-8 m-4 min-h-[300px] flex flex-col items-center justify-center border-2 border-dashed border-secondary/40 rounded-xl bg-background/30">
            @if (Model.MonthlyLossData != null && Model.MonthlyLossData.Any())
            {
                <canvas id="monthlyLossChart"></canvas>
            }
            else
            {
                <p class="text-primary font-bold text-center opacity-70">
                    Ще немає даних для побудови графіка.<br />Час іти прокрастинувати!
                </p>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const canvas = document.getElementById('monthlyLossChart');
            if (!canvas) return;

            const ctx = canvas.getContext('2d');

            const rootStyles = getComputedStyle(document.documentElement);
            const getColor = (name) => rootStyles.getPropertyValue(name).trim();

            const colorAccent = getColor('--color-accent');
            const colorText = getColor('--color-text');
            const colorPrimary = getColor('--color-primary');
            const colorSecondary = getColor('--color-secondary');

            const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyLossData.Select(d => d.Key)));
            const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyLossData.Select(d => d.Value)));

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Витрачено хвилин',
                        data: data,
                        borderColor: colorAccent,
                        backgroundColor: colorAccent + '30',
                        borderWidth: 3,
                        pointBackgroundColor: colorText,
                        pointBorderColor: '#fff',
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        tension: 0.3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            backgroundColor: colorText,
                            titleFont: {
                                family: 'Inter',
                                size: 13
                            },
                            bodyFont: {
                                family: 'Inter',
                                size: 14,
                                weight: 'bold'
                            },
                            padding: 10,
                            cornerRadius: 8,
                            displayColors: false
                        }
                    },
                    scales: {
                        x: {
                            ticks: {
                                color: colorText,
                                font: {
                                    family: 'Inter',
                                    weight: '600',
                                    size: 13
                                }
                            },
                            grid: {
                                display: true
                            }
                        },
                        y: {
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: 'Витрачено хвилин',
                                color: colorText,
                                font: {
                                    family: 'Inter',
                                    size: 13,
                                    weight: '600'
                                },
                                padding: {
                                    bottom: 10
                                }
                            },
                            ticks: {
                                precision: 0,
                                color: colorPrimary,
                                font: {
                                    family: 'Inter',
                                    size: 12
                                }
                            },
                            grid: {
                                display: true
                            }
                        }
                    }
                }
            });
        });
    </script>
}