@model ProcrastiInfrastructure.Models.ProfileViewModel

@{
    ViewData["Title"] = "Профіль";
}

<div class="max-w-5xl mx-auto space-y-6 mt-4">

    <div class="bg-surface border border-secondary/50 rounded-xl p-8 flex items-center gap-6 shadow-sm relative">

        <div class="absolute top-6 right-6">
            <a asp-controller="Titles" asp-action="Index" class="btn btn-sm bg-background border-secondary/50 text-text hover:bg-secondary/20 hover:border-secondary transition-colors rounded-lg shadow-sm">
                ⚙️ Змінити титул
            </a>
        </div>

        <img src="@(string.IsNullOrEmpty(Model.ProfilePicture) ? "/images/avatars/default-avatar.png" : Model.ProfilePicture)"
             alt="Avatar"
             class="w-28 h-28 rounded-full object-cover border-4 border-background shadow-md shrink-0" />

        <div class="flex flex-col">
            <h2 class="text-3xl font-black text-text">@Model.Username</h2>
            <span class="text-accent font-bold text-base mt-1 tracking-wide">
                @(string.IsNullOrEmpty(Model.CurrentTitle) ? "Нема титулу" : Model.CurrentTitle)
            </span>
            <span class="text-primary text-sm mt-3 italic">
                Почав вести облік страждань з @Model.JoinedDate?.ToString("dd.MM.yyyy")
            </span>
        </div>
    </div>

    <div class="grid grid-cols-3 gap-4">

        <div class="bg-accent/10 border border-accent/30 rounded-xl p-5 flex flex-col items-center justify-center shadow-sm text-center">
            <span class="text-3xl mb-2 drop-shadow-sm">🏆</span>
            <span class="text-3xl font-black text-text">@Model.AchievementsCount</span>
            <span class="text-xs font-bold text-primary uppercase mt-1">Досягнень</span>
        </div>

        <div class="bg-accent/10 border border-accent/30 rounded-xl p-5 flex flex-col items-center justify-center shadow-sm text-center">
            <span class="text-3xl mb-2 drop-shadow-sm">👑</span>
            <span class="text-3xl font-black text-text">@Model.TitlesCount</span>
            <span class="text-xs font-bold text-primary uppercase mt-1">Титулів</span>
        </div>

        <div class="bg-accent/10 border border-accent/30 rounded-xl p-5 flex flex-col items-center justify-center shadow-sm text-center">
            <span class="text-3xl mb-2 drop-shadow-sm">⏳</span>
            <span class="text-3xl font-black text-text">@Model.TotalLoss</span>
            <span class="text-xs font-bold text-primary uppercase mt-1">Витрачено хвилин</span>
        </div>

    </div>

    <div class="bg-surface border border-secondary/50 rounded-xl overflow-hidden shadow-sm">
        <div class="px-5 py-3 border-b border-secondary/50 bg-background/60 flex justify-between items-center">
            <h3 class="font-bold text-text text-base">Останні записи</h3>
        </div>

        <div class="flex flex-col">
            @if (Model.RecentLogs.Any())
            {
                foreach (var log in Model.RecentLogs)
                {
                    <partial name="_LogCard" model="log" />
                }
            }
            else
            {
                <div class="p-8 text-center text-primary font-bold">І досі не створив жодного запису!?</div>
            }
        </div>
    </div>

    <div class="bg-surface border border-secondary/50 rounded-xl overflow-hidden shadow-sm">
        <div class="px-5 py-3 border-b border-secondary/50 bg-background/60 flex justify-between items-center">
            <h3 class="font-bold text-text text-base">Невтішний графік витрат за місяць</h3>
        </div>

        <div class="p-8 m-4 min-h-[300px] flex flex-col items-center justify-center border-2 border-dashed border-secondary/40 rounded-xl bg-background/30">
            @if (Model.MonthlyLossData != null && Model.MonthlyLossData.Any())
            {
                <canvas id="monthlyLossChart"></canvas>
            }
            else
            {
                <p class="text-primary font-bold text-center opacity-70">
                    Ще немає даних для побудови графіка.<br />Час іти прокрастинувати!
                </p>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const canvas = document.getElementById('monthlyLossChart');
            if (!canvas) return;

            const ctx = canvas.getContext('2d');

            const rootStyles = getComputedStyle(document.documentElement);
            const getColor = (name) => rootStyles.getPropertyValue(name).trim();

            const colorAccent = getColor('--color-accent');
            const colorText = getColor('--color-text');
            const colorPrimary = getColor('--color-primary');
            const colorSecondary = getColor('--color-secondary');

            const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyLossData.Select(d => d.Key)));
            const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyLossData.Select(d => d.Value)));

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Витрачено хвилин',
                        data: data,
                        borderColor: colorAccent,
                        backgroundColor: colorAccent + '30',
                        borderWidth: 3,
                        pointBackgroundColor: colorText,
                        pointBorderColor: '#fff',
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        tension: 0.3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            backgroundColor: colorText,
                            titleFont: {
                                family: 'Inter',
                                size: 13
                            },
                            bodyFont: {
                                family: 'Inter',
                                size: 14,
                                weight: 'bold'
                            },
                            padding: 10,
                            cornerRadius: 8,
                            displayColors: false
                        }
                    },
                    scales: {
                        x: {
                            ticks: {
                                color: colorText,
                                font: {
                                    family: 'Inter',
                                    weight: '600',
                                    size: 13
                                }
                            },
                            grid: {
                                display: true
                            }
                        },
                        y: {
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: 'Витрачено хвилин',
                                color: colorText,
                                font: {
                                    family: 'Inter',
                                    size: 13,
                                    weight: '600'
                                },
                                padding: {
                                    bottom: 10
                                }
                            },
                            ticks: {
                                precision: 0,
                                color: colorPrimary,
                                font: {
                                    family: 'Inter',
                                    size: 12
                                }
                            },
                            grid: {
                                display: true
                            }
                        }
                    }
                }
            });
        });
    </script>
}