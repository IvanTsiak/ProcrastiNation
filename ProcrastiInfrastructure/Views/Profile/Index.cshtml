@model ProcrastiInfrastructure.Models.ProfileViewModel

@{
    ViewData["Title"] = "Профіль";
}

<div class="max-w-5xl mx-auto space-y-6 mt-4">

    <div class="bg-surface border border-secondary/50 rounded-xl p-8 flex items-center gap-6 shadow-sm relative">

        @if (Model.IsCurrentUser)
        {
            <div class="absolute top-6 right-6">
                <a asp-controller="Titles" asp-action="Index" class="btn btn-sm bg-background border-secondary/50 text-text hover:bg-secondary/20 hover:border-secondary transition-colors rounded-lg shadow-sm">
                    Змінити титул
                </a>
                <a asp-controller="Settings" asp-action="Index" class="btn btn-sm btn-square bg-background border-secondary/50 text-text hover:bg-secondary/20 hover:border-secondary transition-colors rounded-lg shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 20" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                        <path d="M8.05893 3.44669C8.10485 2.96364 8.32921 2.51506 8.68818 2.18859C9.04716 1.86212 9.51495 1.68121 10.0002 1.68121C10.4854 1.68121 10.9532 1.86212 11.3122 2.18859C11.6712 2.51506 11.8955 2.96364 11.9414 3.44669C11.969 3.75874 12.0714 4.05954 12.2399 4.32364C12.4084 4.58774 12.638 4.80737 12.9093 4.96392C13.1807 5.12048 13.4857 5.20936 13.7987 5.22304C14.1116 5.23672 14.4233 5.1748 14.7073 5.04252C15.1482 4.84234 15.6478 4.81337 16.1089 4.96126C16.57 5.10915 16.9596 5.42332 17.2019 5.84261C17.4441 6.26191 17.5217 6.75633 17.4195 7.22967C17.3173 7.703 17.0426 8.12137 16.6489 8.40336C16.3926 8.58323 16.1833 8.8222 16.0389 9.10005C15.8944 9.37789 15.819 9.68645 15.819 9.99961C15.819 10.3128 15.8944 10.6213 16.0389 10.8992C16.1833 11.177 16.3926 11.416 16.6489 11.5959C17.0426 11.8778 17.3173 12.2962 17.4195 12.7695C17.5217 13.2429 17.4441 13.7373 17.2019 14.1566C16.9596 14.5759 16.57 14.8901 16.1089 15.038C15.6478 15.1858 15.1482 15.1569 14.7073 14.9567C14.4233 14.8244 14.1116 14.7625 13.7987 14.7762C13.4857 14.7899 13.1807 14.8787 12.9093 15.0353C12.638 15.1918 12.4084 15.4115 12.2399 15.6756C12.0714 15.9397 11.969 16.2405 11.9414 16.5525C11.8955 17.0356 11.6712 17.4842 11.3122 17.8106C10.9532 18.1371 10.4854 18.318 10.0002 18.318C9.51495 18.318 9.04716 18.1371 8.68818 17.8106C8.32921 17.4842 8.10485 17.0356 8.05893 16.5525C8.03138 16.2404 7.92901 15.9394 7.76049 15.6753C7.59196 15.4111 7.36224 15.1914 7.09079 15.0348C6.81934 14.8782 6.51416 14.7894 6.20108 14.7758C5.88801 14.7622 5.57627 14.8242 5.29227 14.9567C4.85134 15.1569 4.3517 15.1858 3.8906 15.038C3.42949 14.8901 3.03991 14.5759 2.79767 14.1566C2.55543 13.7373 2.47786 13.2429 2.58007 12.7695C2.68227 12.2962 2.95693 11.8778 3.3506 11.5959C3.60695 11.416 3.81621 11.177 3.96067 10.8992C4.10514 10.6213 4.18056 10.3128 4.18056 9.99961C4.18056 9.68645 4.10514 9.37789 3.96067 9.10005C3.81621 8.8222 3.60695 8.58323 3.3506 8.40336C2.95749 8.12123 2.68331 7.70302 2.58135 7.23001C2.47939 6.7